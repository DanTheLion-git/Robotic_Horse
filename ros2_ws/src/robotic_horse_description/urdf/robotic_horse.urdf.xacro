<?xml version="1.0"?>
<!--
  Robotic Horse — Gazebo / ROS2 URDF
  ===================================
  This is the Gazebo-compatible version of the robot description.
  It extends the base URDF with:
    • <ros2_control> hardware interface tags  (8 controlled joints)
    • <gazebo> plugin tag  (loads gazebo_ros2_control)
    • <gazebo> material + contact tags per link

  Leg layout (top view):
      FL –––– FR
      |        |
      RL –––– RR

  Controlled joints (8 total):
      {fl,fr,rl,rr}_thigh_joint  — hip flexion/extension  (position ctrl)
      {fl,fr,rl,rr}_knee_joint   — knee driven by ballscrew (position ctrl)

  Fixed joints (set at 0, no actuator needed for cart-supported robot):
      {fl,fr,rl,rr}_hip_joint    — lateral hip bracket

  Physical parameters (edit here and in ros2_control.yaml):
    Body mass  : 20 kg
    Thigh      : 0.45 m,  1.5 kg
    Shank      : 0.50 m,  1.0 kg
    Foot sphere: r=0.04 m, 0.2 kg
-->
<robot name="robotic_horse" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════ -->
  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1"/></material>
  <material name="orange">     <color rgba="0.90 0.40 0.00 1"/></material>
  <material name="light_grey"> <color rgba="0.70 0.70 0.70 1"/></material>
  <material name="black">      <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="silver">     <color rgba="0.75 0.75 0.80 1"/></material>
  <material name="body_panel"> <color rgba="0.25 0.25 0.30 1"/></material>
  <material name="wood">       <color rgba="0.55 0.35 0.15 1"/></material>
  <material name="iron">       <color rgba="0.28 0.28 0.28 1"/></material>

  <!-- ═══════════════════════════════════════════════════════
       IMU SENSOR  — provides body orientation for self-balance
       Published on /imu/data (bridged from gz transport).
       Pitch (Y) used to adapt foot step heights per leg.
       Roll  (X) used to adapt hip Z splay at idle.
  ═══════════════════════════════════════════════════════ -->

  <!-- IMU sensor on base_link — publishes body orientation for balance -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu/data</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>


  <!-- ═══════════════════════════════════════════════════════
       CART  —  Root link. Acts as stabilising chassis for the elk.
       VW-Up size: 3.2m L x 1.4m W x 0.7m H body, 1.0m-diameter wheels.
       Two parallel shaft arms connect to a wide collar that prevents
       the horse from rolling left/right (only yaw + limited pitch free).
       Horse is a FIXED child of the collar — no X-axis freedom = no roll.
  ═══════════════════════════════════════════════════════ -->

  <!-- Cart body (root link — entire robot tree starts here) -->
  <link name="cart_base">
    <inertial>
      <mass value="350.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- 3.2×1.4×0.7m box: Ixx=m(y²+z²)/12, Iyy=m(x²+z²)/12, Izz=m(x²+y²)/12 -->
      <inertia ixx="71.5" iyy="313.0" izz="355.8" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main carriage box -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="3.2 1.4 0.7"/></geometry>
      <material name="wood"/>
    </visual>
    <!-- Roof panel -->
    <visual>
      <origin xyz="0.20 0 0.35" rpy="0 0 0"/>
      <geometry><box size="2.6 1.35 0.05"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Front fascia -->
    <visual>
      <origin xyz="1.58 0 0.10" rpy="0 0 0"/>
      <geometry><box size="0.06 1.35 0.50"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="3.2 1.4 0.7"/></geometry>
    </collision>
  </link>
  <gazebo reference="cart_base">
    <material>Gazebo/WoodPallet</material>
  </gazebo>

  <!-- ── CART WHEELS (1.0m diameter, continuous) ──────────────────── -->

  <link name="cart_fl_wheel_link">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- Solid cylinder: Ixx=Izz=m(3r²+l²)/12, Iyy=mr²/2 -->
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry>
    </collision>
  </link>
  <joint name="cart_fl_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_fl_wheel_link"/>
    <origin xyz="1.2 0.72 -0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_fl_wheel_link">
    <material>Gazebo/FlatBlack</material>
    <mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd>
  </gazebo>

  <link name="cart_fr_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_fr_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_fr_wheel_link"/>
    <origin xyz="1.2 -0.72 -0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_fr_wheel_link">
    <material>Gazebo/FlatBlack</material>
    <mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd>
  </gazebo>

  <link name="cart_rl_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_rl_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_rl_wheel_link"/>
    <origin xyz="-1.2 0.72 -0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_rl_wheel_link">
    <material>Gazebo/FlatBlack</material>
    <mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd>
  </gazebo>

  <link name="cart_rr_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_rr_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_rr_wheel_link"/>
    <origin xyz="-1.2 -0.72 -0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_rr_wheel_link">
    <material>Gazebo/FlatBlack</material>
    <mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd>
  </gazebo>

  <!-- ── SHAFT ARMS  —  two parallel poles running alongside the horse ─── -->
  <!-- Pivot (cart_to_shaft_steer) is at cart front at horse-body height.   -->
  <!-- Arms spread to ±0.25m spanning the horse body (0.38m wide).         -->
  <!-- This wide stance mechanically prevents roll via geometry.            -->
  <link name="shaft_steer_link">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="1.25 0 0" rpy="0 0 0"/>
      <inertia ixx="0.040" iyy="1.680" izz="1.680" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Left shaft arm -->
    <visual>
      <origin xyz="1.25 0.25 0" rpy="0 0 0"/>
      <geometry><box size="2.50 0.06 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Right shaft arm -->
    <visual>
      <origin xyz="1.25 -0.25 0" rpy="0 0 0"/>
      <geometry><box size="2.50 0.06 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Cross brace at pivot end -->
    <visual>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.56 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Cross brace at collar end -->
    <visual>
      <origin xyz="2.46 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.56 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <collision>
      <origin xyz="1.25 0 0" rpy="0 0 0"/>
      <geometry><box size="2.50 0.56 0.08"/></geometry>
    </collision>
  </link>
  <!-- cart_to_shaft_steer: PASSIVE yaw joint — horse turns, pulls cart around. -->
  <!-- Limits ±35° so horse can turn tightly without jackknifing the cart.     -->
  <joint name="cart_to_shaft_steer" type="revolute">
    <parent link="cart_base"/><child link="shaft_steer_link"/>
    <origin xyz="1.6 0 0.42" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.61" upper="0.61" effort="200" velocity="2.0"/>
    <dynamics damping="15.0" friction="3.0"/>
  </joint>
  <gazebo reference="shaft_steer_link"><material>Gazebo/Grey</material></gazebo>

  <!-- ── COLLAR  —  wide yoke that prevents horse rolling L/R ─────────── -->
  <!-- collar_to_horse is FIXED — no X rotation possible = roll prevented.  -->
  <!-- Only freedoms are: Z-yaw (cart_to_shaft_steer) + Y-pitch (here).    -->
  <link name="horse_collar_link">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.060" iyy="0.010" izz="0.062" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Wide collar bar spanning both sides of horse body -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.58 0.32"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Side attachment brackets (show the connection points on horse sides) -->
    <visual>
      <origin xyz="0 0.29 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 -0.29 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
      <material name="silver"/>
    </visual>
    <!-- NO collision geometry — collar is fixed to horse body, no contact needed -->
  </link>
  <!-- shaft_to_collar: PASSIVE pitch joint — horse pitches over bumps. -->
  <!-- Tight limits ±12° + high damping keeps horse level while gait runs.  -->
  <joint name="shaft_to_collar" type="revolute">
    <parent link="shaft_steer_link"/><child link="horse_collar_link"/>
    <origin xyz="2.50 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.21" upper="0.21" effort="500" velocity="2.0"/>
    <dynamics damping="50.0" friction="10.0"/>
  </joint>
  <gazebo reference="horse_collar_link"><material>Gazebo/Grey</material></gazebo>

  <!-- FIXED: horse body is rigidly attached to collar. Collar is 0.30m behind
       horse center so arms connect at haunch area (like real carriage harness). -->
  <joint name="collar_to_horse" type="fixed">
    <parent link="horse_collar_link"/><child link="base_link"/>
    <origin xyz="0.30 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════ -->
  <!-- Elk animatronic body: 45kg (frame 18kg + motors 15kg + costume 12kg)
       CoM shifted -0.15m rear to counterbalance neck/head forward mass. -->
  <link name="base_link">
    <inertial>
      <mass value="60.0"/>
      <origin xyz="-0.10 0 0" rpy="0 0 0"/>
      <inertia ixx="2.234" iyy="7.563" izz="6.772" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main body panel -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.10 0.38 0.55"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Top saddle plate -->
    <visual>
      <origin xyz="-0.06 0 0.275" rpy="0 0 0"/>
      <geometry><box size="0.70 0.32 0.04"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.10 0.45 0.55"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       NECK + HEAD  (basic elk silhouette geometry)
  ═══════════════════════════════════════════════════════ -->

  <!-- Neck: angled 45 deg forward from vertical.
       Joint origin at front-top of body (withers area). -->
  <link name="neck_link">
    <inertial><mass value="2.5"/><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <inertia ixx="0.080" iyy="0.080" izz="0.015" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.12" length="0.55"/></geometry><material name="body_panel"/></visual>
    <collision><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.10" length="0.55"/></geometry></collision>
  </link>
  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/><child link="neck_link"/>
    <origin xyz="0.52 0 0.265" rpy="0 -0.698 0"/>
  </joint>
  <gazebo reference="neck_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Head: skull box + snout extension -->
  <link name="head_link">
    <inertial><mass value="1.2"/><origin xyz="0.10 0 0" rpy="0 0 0"/>
      <inertia ixx="0.010" iyy="0.020" izz="0.016" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Skull -->
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.40 0.18 0.28"/></geometry><material name="body_panel"/></visual>
    <!-- Snout / muzzle extending forward -->
    <visual><origin xyz="0.32 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.28 0.13 0.17"/></geometry><material name="body_panel"/></visual>
    <!-- Nose tip (darker) -->
    <visual><origin xyz="0.46 0 -0.06" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.10"/></geometry><material name="black"/></visual>
    <!-- Eye sockets -->
    <visual><origin xyz="-0.05 0.09 0.06" rpy="0 0 0"/>
      <geometry><sphere radius="0.028"/></geometry><material name="black"/></visual>
    <visual><origin xyz="-0.05 -0.09 0.06" rpy="0 0 0"/>
      <geometry><sphere radius="0.028"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.55 0.18 0.28"/></geometry></collision>
  </link>
  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/><child link="head_link"/>
    <origin xyz="0 0 0.55" rpy="0 0.698 0"/>
  </joint>
  <gazebo reference="head_link"><material>Gazebo/Brown</material></gazebo>

  <!-- ═══════════════════════════════════════════════════════
       LEG LINKS & JOINTS  (macro-expanded for FL/FR/RL/RR)
  ═══════════════════════════════════════════════════════ -->

  <!-- ── FRONT-LEFT ── -->
  <link name="fl_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.07" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="fl_hip_joint" type="revolute">
    <parent link="base_link"/><child link="fl_hip_link"/>
    <origin xyz="0.43 0.19 -0.22" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_hip_link"><material>Gazebo/Grey</material></gazebo>

  <link name="fl_thigh_link">
    <inertial><mass value="5.5"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <inertia ixx="0.170" iyy="0.170" izz="0.010" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <geometry><box size="0.055 0.055 0.38"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.035 0 -0.19" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.25"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.19" rpy="0 0 0">
      </origin><geometry><box size="0.055 0.055 0.38"/></geometry></collision>
  </link>
  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/><child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_thigh_link"><material>Gazebo/Orange</material></gazebo>

  <link name="fl_shank_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <inertia ixx="0.122" iyy="0.122" izz="0.004" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.18" rpy="0 0 0">
      </origin><geometry><box size="0.045 0.045 0.36"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.18" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.36"/></geometry></collision>
  </link>
  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/><child link="fl_shank_link"/>
    <origin xyz="0 0 -0.38" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="fl_cannon_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.125" rpy="0 0 0"/>
      <inertia ixx="0.0053" iyy="0.0053" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.015" length="0.25"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.012" length="0.25"/></geometry></collision>
  </link>
  <joint name="fl_cannon_joint" type="revolute">
    <parent link="fl_shank_link"/><child link="fl_cannon_link"/>
    <origin xyz="0 0 -0.36" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="fl_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="fl_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.05"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
