  <!-- ═══════════════════════════════════════════════════════
       ROS2 CONTROL — hardware interface
       (gazebo_ros2_control reads this at runtime)
       12 commanded joints: 4x hip(Z) + 4x thigh(Y) + 4x knee(Y)
       2 passive joints: cart_to_shaft_steer, shaft_to_horse
  ═══════════════════════════════════════════════════════ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Steering joint — position commanded by blendspace_node -->
    <joint name="cart_to_shaft_steer">
      <command_interface name="position">
        <param name="min">-0.61</param><param name="max">0.61</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Passive pitch joint — state only -->
    <joint name="shaft_to_horse">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Front-left -->
    <joint name="fl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.516</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.031</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.666</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-right -->
    <joint name="fr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.516</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.031</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.666</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-left -->
    <joint name="rl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.516</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.031</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.366</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-right -->
    <joint name="rr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.516</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.031</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.366</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════
       GAZEBO PLUGIN — loads gazebo_ros2_control
  ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robotic_horse_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
