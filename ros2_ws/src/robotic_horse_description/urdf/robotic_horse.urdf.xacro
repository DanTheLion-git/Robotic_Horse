  </link>
  <joint name="rr_knee_joint" type="revolute">
    <parent link="rr_thigh_link"/><child link="rr_shank_link"/>
    <origin xyz="0 0 -0.50" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="0.10" upper="1.80" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="rr_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="rr_cannon_link">
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.11" rpy="0 0 0"/>
      <inertia ixx="0.0049" iyy="0.0049" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.11" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.22"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.11" rpy="0 0 0"/>
