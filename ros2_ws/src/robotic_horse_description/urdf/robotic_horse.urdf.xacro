  <!-- ═══════════════════════════════════════════════════════
       CARRIAGE — vis-à-vis style, hitched to bovine robot
       Real measurements from owner's carriage:
         Front wheels ⌀ 85 cm,  Rear wheels ⌀ 105 cm
         Wheelbase 205 cm,  Track 145 cm
         Shaft 235 cm long, U-shaped, 85→70 cm wide
         Hitch: 50 cm fwd + 37 cm above front wheel center
         Body: 250 × 110 × 110 cm, ~60 cm off ground
         Driver: ~85 kg on front bench
       Total carriage mass ≈ 105 kg + 85 kg driver = 190 kg
  ═══════════════════════════════════════════════════════ -->

  <!-- Shaft yaw joint (base_link → shaft) — continuous rotation (infinite turn angle) -->
  <joint name="shaft_yaw_joint" type="continuous">
    <parent link="base_link"/><child link="shaft_link"/>
    <origin xyz="0.0 0 -0.30" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>

  <!-- Shaft — U-shaped wooden fork, 2.35m long -->
  <link name="shaft_link">
    <inertial><mass value="15.0"/><origin xyz="-1.175 0 0" rpy="0 0 0"/>
      <inertia ixx="0.10" iyy="6.93" izz="6.95" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Left shaft bar -->
    <visual><origin xyz="-1.175 0.39 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-1.175 0.39 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry></collision>
    <!-- Right shaft bar -->
    <visual><origin xyz="-1.175 -0.39 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-1.175 -0.39 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry></collision>
    <!-- Cross piece at carriage end -->
    <visual><origin xyz="-2.30 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.70 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-2.30 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.70 0.05"/></geometry></collision>
  </link>

  <!-- Shaft pitch joint — allows carriage to pitch on uneven ground -->
  <joint name="shaft_pitch_joint" type="revolute">
    <parent link="shaft_link"/><child link="cart_hitch_link"/>
    <origin xyz="-2.35 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.20" upper="0.20" effort="0" velocity="2.0"/>
    <dynamics damping="15.0" friction="0.5"/>
  </joint>

  <!-- Hitch pin (small connector) -->
  <link name="cart_hitch_link">
    <inertial><mass value="2.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.12"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.12"/></geometry></collision>
  </link>

  <!-- Cart body (fixed to hitch) — vis-à-vis carriage -->
  <joint name="cart_body_joint" type="fixed">
    <parent link="cart_hitch_link"/><child link="cart_body_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Cart body — 250×110×110 cm wooden carriage body
       Body center at (-1.525, 0, +0.355) from hitch
       Driver (85 kg) seated on front bench at (-0.90, 0, +0.80) from hitch -->
  <link name="cart_body_link">
    <!-- Combined inertia: carriage structure 55 kg + driver 85 kg = 140 kg
         Approximate as box 2.50×1.10×1.10 at combined COM -->
    <inertial><mass value="140.0"/><origin xyz="-1.40 0 0.42" rpy="0 0 0"/>
      <inertia ixx="25.0" iyy="95.0" izz="85.0" ixy="0" ixz="0" iyz="0"/></inertial>

    <!-- Main body floor/deck -->
    <visual><origin xyz="-1.525 0 0.16" rpy="0 0 0"/>
      <geometry><box size="2.50 1.10 0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-1.525 0 0.16" rpy="0 0 0"/>
      <geometry><box size="2.50 1.10 0.06"/></geometry></collision>

    <!-- Left side panel (curved in real life — approximated with box) -->
    <visual><origin xyz="-1.525 0.52 0.55" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-1.525 0.52 0.55" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry></collision>

    <!-- Right side panel -->
    <visual><origin xyz="-1.525 -0.52 0.55" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="-1.525 -0.52 0.55" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry></collision>

    <!-- Front panel (driver side, with kick board — black leather) -->
    <visual><origin xyz="-0.45 0 0.50" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.62"/></geometry><material name="dark_grey"/></visual>

    <!-- Rear panel -->
    <visual><origin xyz="-2.60 0 0.50" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.62"/></geometry><material name="dark_grey"/></visual>

    <!-- Center divider panel -->
    <visual><origin xyz="-1.525 0 0.50" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.50"/></geometry><material name="dark_grey"/></visual>

    <!-- Front bench seat (driver sits here, facing backward) -->
    <visual><origin xyz="-0.80 0 0.46" rpy="0 0 0"/>
      <geometry><box size="0.45 0.90 0.08"/></geometry><material name="red_velvet"/></visual>
    <!-- Front seat backrest -->
    <visual><origin xyz="-0.58 0 0.68" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.36"/></geometry><material name="wood"/></visual>

    <!-- Rear bench seat (passengers, facing forward) -->
    <visual><origin xyz="-2.25 0 0.46" rpy="0 0 0"/>
      <geometry><box size="0.45 0.90 0.08"/></geometry><material name="red_velvet"/></visual>
    <!-- Rear seat backrest -->
    <visual><origin xyz="-2.47 0 0.68" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.36"/></geometry><material name="wood"/></visual>

    <!-- Driver figure (85 kg, seated on front bench) -->
    <!-- Torso -->
    <visual><origin xyz="-0.80 0 0.82" rpy="0 0 0"/>
      <geometry><box size="0.30 0.40 0.55"/></geometry><material name="dark_grey"/></visual>
    <!-- Head -->
    <visual><origin xyz="-0.80 0 1.17" rpy="0 0 0"/>
      <geometry><sphere radius="0.12"/></geometry><material name="light_grey"/></visual>

    <!-- Left mudguard / fender (over rear wheels) -->
    <visual><origin xyz="-2.35 0.58 0.10" rpy="0 0 0"/>
      <geometry><box size="0.70 0.12 0.06"/></geometry><material name="wood"/></visual>
    <!-- Right mudguard -->
    <visual><origin xyz="-2.35 -0.58 0.10" rpy="0 0 0"/>
      <geometry><box size="0.70 0.12 0.06"/></geometry><material name="wood"/></visual>

    <!-- Iron underframe / chassis rail (left) -->
    <visual><origin xyz="-1.525 0.40 -0.05" rpy="0 0 0"/>
      <geometry><box size="2.60 0.04 0.04"/></geometry><material name="iron"/></visual>
    <!-- Iron underframe / chassis rail (right) -->
    <visual><origin xyz="-1.525 -0.40 -0.05" rpy="0 0 0"/>
      <geometry><box size="2.60 0.04 0.04"/></geometry><material name="iron"/></visual>

    <!-- Left carriage lamp bracket -->
    <visual><origin xyz="-0.35 0.50 0.95" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="iron"/></visual>
    <!-- Left lamp housing -->
    <visual><origin xyz="-0.35 0.54 1.10" rpy="0 0 0"/>
      <geometry><box size="0.10 0.10 0.15"/></geometry><material name="iron"/></visual>
    <!-- Right carriage lamp bracket -->
    <visual><origin xyz="-0.35 -0.50 0.95" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="iron"/></visual>
    <!-- Right lamp housing -->
    <visual><origin xyz="-0.35 -0.54 1.10" rpy="0 0 0"/>
      <geometry><box size="0.10 0.10 0.15"/></geometry><material name="iron"/></visual>

    <!-- Folding hood frame (rear, collapsed) -->
    <visual><origin xyz="-2.55 0 1.00" rpy="0 0 0"/>
      <geometry><box size="0.08 0.95 0.15"/></geometry><material name="wood"/></visual>
  </link>

  <!-- ── Front axle (steering) ── -->
  <joint name="front_axle_joint" type="revolute">
    <parent link="cart_body_link"/><child link="front_axle_link"/>
    <origin xyz="-0.50 0 -0.37" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="0" velocity="2.0"/>
    <dynamics damping="20.0" friction="0.5"/>
  </joint>
  <link name="front_axle_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.53" iyy="0.003" izz="0.53" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry></collision>
  </link>

  <!-- ── Rear axle (fixed) ── -->
  <joint name="rear_axle_joint" type="fixed">
    <parent link="cart_body_link"/><child link="rear_axle_link"/>
    <origin xyz="-2.55 0 -0.27" rpy="0 0 0"/>
  </joint>
  <link name="rear_axle_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.53" iyy="0.003" izz="0.53" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry></collision>
  </link>

  <!-- ── Front-Left Wheel (⌀85cm) ── -->
  <joint name="cart_fl_wheel_joint" type="continuous">
    <parent link="front_axle_link"/><child link="cart_fl_wheel_link"/>
    <origin xyz="0 0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_fl_wheel_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.091" iyy="0.181" izz="0.091" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry></collision>
    <!-- Wheel hub -->
    <visual><origin xyz="0 0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Front-Right Wheel (⌀85cm) ── -->
  <joint name="cart_fr_wheel_joint" type="continuous">
    <parent link="front_axle_link"/><child link="cart_fr_wheel_link"/>
    <origin xyz="0 -0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_fr_wheel_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.091" iyy="0.181" izz="0.091" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry></collision>
    <visual><origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Rear-Left Wheel (⌀105cm) ── -->
  <joint name="cart_rl_wheel_joint" type="continuous">
    <parent link="rear_axle_link"/><child link="cart_rl_wheel_link"/>
    <origin xyz="0 0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_rl_wheel_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.174" iyy="0.345" izz="0.174" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry></collision>
    <visual><origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Rear-Right Wheel (⌀105cm) ── -->
  <joint name="cart_rr_wheel_joint" type="continuous">
    <parent link="rear_axle_link"/><child link="cart_rr_wheel_link"/>
    <origin xyz="0 -0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_rr_wheel_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.174" iyy="0.345" izz="0.174" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry></collision>
    <visual><origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Gazebo contact/material for carriage ── -->
  <gazebo reference="shaft_link"><material>Gazebo/Wood</material></gazebo>
  <gazebo reference="cart_hitch_link"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="cart_body_link"><material>Gazebo/Wood</material></gazebo>
  <gazebo reference="front_axle_link"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="rear_axle_link"><material>Gazebo/Grey</material></gazebo>

  <gazebo reference="cart_fl_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_fr_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_rl_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_rr_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       ROS2 CONTROL — hardware interface
       16 commanded joints: 4x hip(Z) + 4x thigh(Y) + 4x knee(Y) + 4x cannon(Y)
       Carriage wheels are passive — not included in ros2_control.
  ═══════════════════════════════════════════════════════ -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Front-left -->
    <joint name="fl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.30</param><param name="max">1.20</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.80</param><param name="max">-0.10</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-right -->
    <joint name="fr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.30</param><param name="max">1.20</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.80</param><param name="max">-0.10</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-left -->
    <joint name="rl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.20</param><param name="max">0.30</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position">
        <param name="min">0.10</param><param name="max">1.80</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-right -->
    <joint name="rr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.20</param><param name="max">0.30</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position">
        <param name="min">0.10</param><param name="max">1.80</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════
       GAZEBO PLUGIN — loads gazebo_ros2_control
  ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robotic_horse_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
