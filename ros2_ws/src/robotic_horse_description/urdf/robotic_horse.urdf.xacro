<?xml version="1.0"?>
<!--
  Robotic Horse — Gazebo / ROS2 URDF
  ===================================
  This is the Gazebo-compatible version of the robot description.
  It extends the base URDF with:
    • <ros2_control> hardware interface tags  (17 controlled joints)
    • <gazebo> plugin tag  (loads gazebo_ros2_control)
    • <gazebo> material + contact tags per link

  Leg layout (top view):
      FL –––– FR
      |        |
      RL –––– RR

  Controlled joints (17 total, QDD actuated):
      spine_yaw_joint              — spine lateral bend       (position ctrl)
      {fl,fr,rl,rr}_hip_joint     — lateral hip yaw          (position ctrl)
      {fl,fr,rl,rr}_thigh_joint   — hip flexion/extension    (position ctrl)
      {fl,fr,rl,rr}_knee_joint    — stifle/elbow flexion     (position ctrl)
      {fl,fr,rl,rr}_cannon_joint  — hock/fetlock (coupled)   (position ctrl)

  Physical parameters (edit here and in ros2_control.yaml):
    Body mass  : 107 kg (QDD motors + frame + decoration)
    Front thigh: 0.38 m,  4.0 kg  /  Rear thigh: 0.50 m,  5.0 kg
    Front shank: 0.34 m,  3.5 kg  /  Rear shank: 0.45 m,  4.0 kg
    Front cannon: 0.18 m, 1.0 kg  /  Rear cannon: 0.22 m, 1.2 kg
    Front foot: r=0.05 m, 0.4 kg  /  Rear foot: r=0.06 m, 0.5 kg
-->
<robot name="robotic_horse" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════ -->
  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1"/></material>
  <material name="orange">     <color rgba="0.90 0.40 0.00 1"/></material>
  <material name="light_grey"> <color rgba="0.70 0.70 0.70 1"/></material>
  <material name="black">      <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="silver">     <color rgba="0.75 0.75 0.80 1"/></material>
  <material name="body_panel"> <color rgba="0.25 0.25 0.30 1"/></material>
  <material name="wood">       <color rgba="0.55 0.35 0.15 1"/></material>
  <material name="iron">       <color rgba="0.28 0.28 0.28 1"/></material>
  <material name="red_velvet"> <color rgba="0.60 0.05 0.05 1"/></material>

  <!-- ═══════════════════════════════════════════════════════
       IMU SENSOR  — provides body orientation for self-balance
       Published on /imu/data (bridged from gz transport).
       Pitch (Y) used to adapt foot step heights per leg.
       Roll  (X) used to adapt hip Z splay at idle.
  ═══════════════════════════════════════════════════════ -->

  <!-- IMU sensor on base_link — publishes body orientation for balance -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu/data</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>



  <!-- ═══════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════ -->
  <!-- Body mass ~107 kg: motors(48)+frame(38)+electronics(8)+decoration(8)+legs(5).
       Inertia (107 kg, 1.80x0.88x0.85 m box): Ixx=13.35, Iyy=35.33, Izz=35.80 kg·m²
       Scaled 1.36× from real Highland cow (110cm withers → 150cm) -->
  <!-- base_link = REAR body half (haunches/lumbar).
       Rear legs (RL/RR) and carriage hitch attach here.
       IMU stays on base_link for balance sensing. -->
  <link name="base_link">
    <inertial>
      <mass value="48.0"/>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <inertia ixx="6.0" iyy="6.1" izz="6.3" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Rear barrel half -->
    <visual>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.88 0.75"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Rump (back — at +X) -->
    <visual>
      <origin xyz="0.55 0 0.425" rpy="0 0 0"/>
      <geometry><box size="0.40 0.76 0.10"/></geometry>
      <material name="body_panel"/>
    </visual>

    <collision>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.88 0.85"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       SPINE YAW JOINT — articulated spine for turning
       Connects rear body (base_link) to front body (front_body_link).
       Z-axis rotation allows lateral bending like a real quadruped.
       This is the PRIMARY turning mechanism — combined with
       differential stride length for smooth, natural turns.
  ═══════════════════════════════════════════════════════ -->
  <joint name="spine_yaw_joint" type="revolute">
    <parent link="base_link"/><child link="front_body_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.30" upper="0.30" effort="500" velocity="1.5"/>
    <dynamics damping="12.0" friction="1.0"/>
  </joint>

  <!-- front_body_link = FRONT body half (thorax/shoulders).
       Front legs (FL/FR) and head/neck attach here.
       55% of body mass (bovine weight distribution). -->
  <link name="front_body_link">
    <inertial>
      <mass value="59.0"/>
      <origin xyz="-0.45 0 0" rpy="0 0 0"/>
      <inertia ixx="7.4" iyy="7.5" izz="7.8" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Front barrel half -->
    <visual>
      <origin xyz="-0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.88 0.75"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Withers rise (front shoulder hump) -->
    <visual>
      <origin xyz="-0.50 0 0.475" rpy="0 0 0"/>
      <geometry><box size="0.55 0.78 0.20"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Chest extension (brisket, front-bottom) -->
    <visual>
      <origin xyz="-0.55 0 -0.435" rpy="0 0 0"/>
      <geometry><box size="0.40 0.72 0.12"/></geometry>
      <material name="body_panel"/>
    </visual>

    <collision>
      <origin xyz="-0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.88 0.85"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_body_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ─── HIGHLAND COW HEAD (articulated) ───────────────────── -->
  <!-- Neck: yaw + pitch joints for head motion
       Head: jaw (open/close), eyes (left/right pan)
       Small servos — total head assembly ~6.5 kg
       Attached to front_body_link (thorax) -->

  <!-- Neck yaw — swivel left/right (head faces -X direction of travel) -->
  <link name="neck_yaw_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="neck_yaw_joint" type="revolute">
    <parent link="front_body_link"/><child link="neck_yaw_link"/>
    <origin xyz="-0.85 0 0.42" rpy="0 0 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="15.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <!-- Neck pitch — nod up/down -->
  <link name="neck_link">
    <inertial><mass value="3.0"/><origin xyz="0.10 0 0" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.008" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.22 0.24 0.26"/></geometry><material name="body_panel"/></visual>
    <collision><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.22 0.24 0.26"/></geometry></collision>
  </link>
  <joint name="neck_pitch_joint" type="revolute">
    <parent link="neck_yaw_link"/><child link="neck_link"/>
    <origin xyz="0 0 0" rpy="0 -0.10 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.4" effort="20.0" velocity="2.0"/>
    <dynamics damping="3.0" friction="0.5"/>
  </joint>
  <gazebo reference="neck_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Head link — skull, muzzle, nose, horns (same geometry as before) -->
  <link name="head_link">
    <inertial><mass value="2.0"/><origin xyz="0.15 0 0" rpy="0 0 0"/>
      <inertia ixx="0.016" iyy="0.018" izz="0.013" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Skull — broad Highland Cow head -->
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.38 0.34 0.28"/></geometry><material name="body_panel"/></visual>
    <!-- Muzzle extending forward -->
    <visual><origin xyz="0.25 0 -0.04" rpy="0 0 0">
      </origin><geometry><box size="0.18 0.20 0.16"/></geometry><material name="body_panel"/></visual>
    <!-- LEFT horn: wide sweep outward + slight upward curl — iconic Highland Cow -->
    <visual><origin xyz="-0.06 0.20 0.11" rpy="0.20 0.25 1.30">
      </origin><geometry><cylinder radius="0.025" length="0.50"/></geometry><material name="silver"/></visual>
    <!-- RIGHT horn -->
    <visual><origin xyz="-0.06 -0.20 0.11" rpy="-0.20 -0.25 -1.30">
      </origin><geometry><cylinder radius="0.025" length="0.50"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.60 0.34 0.30"/></geometry></collision>
  </link>
  <joint name="head_nod_joint" type="revolute">
    <parent link="neck_link"/><child link="head_link"/>
    <origin xyz="0.20 0 0" rpy="0 0.10 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3" upper="0.3" effort="8.0" velocity="3.0"/>
    <dynamics damping="1.0" friction="0.3"/>
  </joint>
  <gazebo reference="head_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Jaw — opens downward (mouth) -->
  <link name="jaw_link">
    <inertial><mass value="0.3"/><origin xyz="0.06 0 -0.03" rpy="0 0 0"/>
      <inertia ixx="0.0003" iyy="0.0004" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0.06 0 -0.03" rpy="0 0 0">
      </origin><geometry><box size="0.14 0.16 0.06"/></geometry><material name="body_panel"/></visual>
    <!-- Nose on jaw -->
    <visual><origin xyz="0.12 0 -0.01" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.10 0.05"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0.06 0 -0.03" rpy="0 0 0">
      </origin><geometry><box size="0.14 0.16 0.06"/></geometry></collision>
  </link>
  <joint name="jaw_joint" type="revolute">
    <parent link="head_link"/><child link="jaw_link"/>
    <origin xyz="0.20 0 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.35" upper="0.0" effort="3.0" velocity="4.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <gazebo reference="jaw_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Left eye -->
  <link name="left_eye_link">
    <inertial><mass value="0.05"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><sphere radius="0.025"/></geometry><material name="black"/></visual>
  </link>
  <joint name="left_eye_joint" type="revolute">
    <parent link="head_link"/><child link="left_eye_link"/>
    <origin xyz="0.14 0.14 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.4" upper="0.4" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <gazebo reference="left_eye_link"><material>Gazebo/Black</material></gazebo>

  <!-- Right eye -->
  <link name="right_eye_link">
    <inertial><mass value="0.05"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><sphere radius="0.025"/></geometry><material name="black"/></visual>
  </link>
  <joint name="right_eye_joint" type="revolute">
    <parent link="head_link"/><child link="right_eye_link"/>
    <origin xyz="0.14 -0.14 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.4" upper="0.4" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <gazebo reference="right_eye_link"><material>Gazebo/Black</material></gazebo>

  <!-- Left eyelid (blink) -->
  <link name="left_eyelid_link">
    <inertial><mass value="0.02"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0.005 0 0.012" rpy="0 0 0">
      </origin><geometry><box size="0.01 0.05 0.025"/></geometry><material name="body_panel"/></visual>
  </link>
  <joint name="left_eyelid_joint" type="revolute">
    <parent link="head_link"/><child link="left_eyelid_link"/>
    <origin xyz="0.16 0.14 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.0" effort="0.5" velocity="8.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
  <gazebo reference="left_eyelid_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Right eyelid (blink) -->
  <link name="right_eyelid_link">
    <inertial><mass value="0.02"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0.005 0 0.012" rpy="0 0 0">
      </origin><geometry><box size="0.01 0.05 0.025"/></geometry><material name="body_panel"/></visual>
  </link>
  <joint name="right_eyelid_joint" type="revolute">
    <parent link="head_link"/><child link="right_eyelid_link"/>
    <origin xyz="0.16 -0.14 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.0" effort="0.5" velocity="8.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
  <gazebo reference="right_eyelid_link"><material>Gazebo/Brown</material></gazebo>

  <!-- ═══════════════════════════════════════════════════════
       LEG LINKS & JOINTS  (macro-expanded for FL/FR/RL/RR)
  ═══════════════════════════════════════════════════════ -->

  <!-- ── FRONT-LEFT ── -->
  <link name="fl_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.07" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="fl_hip_joint" type="revolute">
    <parent link="front_body_link"/><child link="fl_hip_link"/>
    <origin xyz="0.65 0.44 -0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_hip_link"><material>Gazebo/Grey</material></gazebo>

  <link name="fl_thigh_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <inertia ixx="0.0496" iyy="0.0496" izz="0.0032" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.38"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.19" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.38"/></geometry></collision>
  </link>
  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/><child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.30" upper="1.20" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_thigh_link"><material>Gazebo/Orange</material></gazebo>

  <link name="fl_shank_link">
    <inertial><mass value="3.5"/><origin xyz="0 0 -0.17" rpy="0 0 0"/>
      <inertia ixx="0.0348" iyy="0.0348" izz="0.0021" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.17" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.035" length="0.34"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.17" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.035" length="0.34"/></geometry></collision>
  </link>
  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/><child link="fl_shank_link"/>
    <origin xyz="0 0 -0.38" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.80" upper="-0.10" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="fl_cannon_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.0028" iyy="0.0028" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.18"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.18"/></geometry></collision>
  </link>
  <joint name="fl_cannon_joint" type="revolute">
    <parent link="fl_shank_link"/><child link="fl_cannon_link"/>
    <origin xyz="0 0 -0.34" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="fl_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="fl_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00040" iyy="0.00040" izz="0.00040" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.05"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.05"/></geometry></collision>
  </link>
  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_cannon_link"/><child link="fl_foot_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fl_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>200.0</kd>
    <mu1>2.0</mu1><mu2>2.0</mu2>
    <minDepth>0.005</minDepth>
  </gazebo>

  <!-- ── FRONT-RIGHT ── -->
  <link name="fr_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="fr_hip_joint" type="revolute">
    <parent link="front_body_link"/><child link="fr_hip_link"/>
    <origin xyz="0.65 -0.44 -0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="fr_thigh_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <inertia ixx="0.0496" iyy="0.0496" izz="0.0032" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.38"/></geometry><material name="orange"/></visual>
