      </origin><geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="rr_hip_joint" type="revolute">
    <parent link="base_link"/><child link="rr_hip_link"/>
    <origin xyz="-0.65 -0.40 0.12" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="rr_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="rr_thigh_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.1068" iyy="0.1068" izz="0.0051" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.045" length="0.50"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.045" length="0.50"/></geometry></collision>
  </link>
  <joint name="rr_thigh_joint" type="revolute">
    <parent link="rr_hip_link"/><child link="rr_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.20" upper="0.30" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
