<?xml version="1.0"?>
<!--
  Robotic Horse — Gazebo / ROS2 URDF
  ===================================
  This is the Gazebo-compatible version of the robot description.
  It extends the base URDF with:
    • <ros2_control> hardware interface tags  (8 controlled joints)
    • <gazebo> plugin tag  (loads gazebo_ros2_control)
    • <gazebo> material + contact tags per link

  Leg layout (top view):
      FL –––– FR
      |        |
      RL –––– RR

  Controlled joints (8 total):
      {fl,fr,rl,rr}_thigh_joint  — hip flexion/extension  (position ctrl)
      {fl,fr,rl,rr}_knee_joint   — knee driven by ballscrew (position ctrl)

  Fixed joints (set at 0, no actuator needed for cart-supported robot):
      {fl,fr,rl,rr}_hip_joint    — lateral hip bracket

  Physical parameters (edit here and in ros2_control.yaml):
    Body mass  : 20 kg
    Thigh      : 0.45 m,  1.5 kg
    Shank      : 0.50 m,  1.0 kg
    Foot sphere: r=0.04 m, 0.2 kg
-->
<robot name="robotic_horse" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════ -->
  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1"/></material>
  <material name="orange">     <color rgba="0.90 0.40 0.00 1"/></material>
  <material name="light_grey"> <color rgba="0.70 0.70 0.70 1"/></material>
  <material name="black">      <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="silver">     <color rgba="0.75 0.75 0.80 1"/></material>
  <material name="body_panel"> <color rgba="0.25 0.25 0.30 1"/></material>
  <material name="wood">       <color rgba="0.55 0.35 0.15 1"/></material>
  <material name="iron">       <color rgba="0.28 0.28 0.28 1"/></material>

  <!-- ═══════════════════════════════════════════════════════
       IMU SENSOR  — provides body orientation for self-balance
       Published on /imu/data (bridged from gz transport).
       Pitch (Y) used to adapt foot step heights per leg.
       Roll  (X) used to adapt hip Z splay at idle.
  ═══════════════════════════════════════════════════════ -->

  <!-- IMU sensor on base_link — publishes body orientation for balance -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu/data</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>



  <!-- ═══════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════ -->
  <!-- Body mass ~100 kg: motors(48)+frame(24)+electronics(8)+decoration(35)+legs(5).
       Inertia (100 kg, 1.40x0.60x0.40 m box): Ixx=4.33, Iyy=17.67, Izz=19.33 kg·m² -->
  <link name="base_link">
    <inertial>
      <mass value="100.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="4.33" iyy="17.67" izz="19.33" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main body panel -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 0.60 0.40"/></geometry>
      <material name="body_panel"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 0.68 0.40"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ─── HIGHLAND COW HEAD ─────────────────────────────────── -->
  <!-- Short thick neck + broad head with characteristic wide horns -->
  <link name="neck_link">
    <inertial><mass value="3.0"/><origin xyz="0.10 0 0" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.008" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.22 0.24 0.26"/></geometry><material name="body_panel"/></visual>
    <collision><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.22 0.24 0.26"/></geometry></collision>
  </link>
  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/><child link="neck_link"/>
    <origin xyz="0.68 0 0.12" rpy="0 -0.10 0"/>
  </joint>
  <gazebo reference="neck_link"><material>Gazebo/Brown</material></gazebo>

  <link name="head_link">
    <inertial><mass value="2.5"/><origin xyz="0.15 0 0" rpy="0 0 0"/>
      <inertia ixx="0.018" iyy="0.020" izz="0.015" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Skull — broad Highland Cow head -->
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.38 0.34 0.28"/></geometry><material name="body_panel"/></visual>
    <!-- Muzzle extending forward -->
    <visual><origin xyz="0.25 0 -0.04" rpy="0 0 0">
      </origin><geometry><box size="0.18 0.20 0.16"/></geometry><material name="body_panel"/></visual>
    <!-- Nose -->
    <visual><origin xyz="0.34 0 -0.05" rpy="0 0 0">
      </origin><geometry><box size="0.05 0.12 0.08"/></geometry><material name="black"/></visual>
    <!-- LEFT horn: wide sweep outward + slight upward curl — iconic Highland Cow -->
    <visual><origin xyz="-0.06 0.20 0.11" rpy="0.20 0.25 1.30">
      </origin><geometry><cylinder radius="0.025" length="0.50"/></geometry><material name="silver"/></visual>
    <!-- RIGHT horn -->
    <visual><origin xyz="-0.06 -0.20 0.11" rpy="-0.20 -0.25 -1.30">
      </origin><geometry><cylinder radius="0.025" length="0.50"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0.10 0 0" rpy="0 0 0">
      </origin><geometry><box size="0.60 0.34 0.30"/></geometry></collision>
  </link>
  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/><child link="head_link"/>
    <origin xyz="0.20 0 0" rpy="0 0.10 0"/>
  </joint>
  <gazebo reference="head_link"><material>Gazebo/Brown</material></gazebo>

  <!-- ═══════════════════════════════════════════════════════
       LEG LINKS & JOINTS  (macro-expanded for FL/FR/RL/RR)
  ═══════════════════════════════════════════════════════ -->

  <!-- ── FRONT-LEFT ── -->
  <link name="fl_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.07" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="fl_hip_joint" type="revolute">
    <parent link="base_link"/><child link="fl_hip_link"/>
    <origin xyz="0.48 0.24 -0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_hip_link"><material>Gazebo/Grey</material></gazebo>

  <link name="fl_thigh_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.022" izz="0.005" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <geometry><box size="0.070 0.070 0.20"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry></collision>
  </link>
  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/><child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_thigh_link"><material>Gazebo/Orange</material></gazebo>

  <link name="fl_shank_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry></collision>
  </link>
  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/><child link="fl_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="fl_cannon_link">
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.10"/></geometry></collision>
  </link>
  <joint name="fl_cannon_joint" type="revolute">
    <parent link="fl_shank_link"/><child link="fl_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="fl_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="fl_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_cannon_link"/><child link="fl_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fl_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── FRONT-RIGHT ── -->
  <link name="fr_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="fr_hip_joint" type="revolute">
    <parent link="base_link"/><child link="fr_hip_link"/>
    <origin xyz="0.48 -0.24 -0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="fr_thigh_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.022" izz="0.005" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry></collision>
  </link>
  <joint name="fr_thigh_joint" type="revolute">
    <parent link="fr_hip_link"/><child link="fr_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="fr_shank_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry></collision>
  </link>
  <joint name="fr_knee_joint" type="revolute">
    <parent link="fr_thigh_link"/><child link="fr_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="fr_cannon_link">
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.10"/></geometry></collision>
  </link>
  <joint name="fr_cannon_joint" type="revolute">
    <parent link="fr_shank_link"/><child link="fr_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="fr_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="fr_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="fr_foot_joint" type="fixed">
    <parent link="fr_cannon_link"/><child link="fr_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fr_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── REAR-LEFT ── -->
  <link name="rl_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="rl_hip_joint" type="revolute">
    <parent link="base_link"/><child link="rl_hip_link"/>
    <origin xyz="-0.48 0.24 -0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="rl_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="rl_thigh_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.022" izz="0.005" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry></collision>
  </link>
  <joint name="rl_thigh_joint" type="revolute">
    <parent link="rl_hip_link"/><child link="rl_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="rl_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="rl_shank_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry></collision>
  </link>
  <joint name="rl_knee_joint" type="revolute">
    <parent link="rl_thigh_link"/><child link="rl_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="rl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="rl_cannon_link">
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.10"/></geometry></collision>
  </link>
  <joint name="rl_cannon_joint" type="revolute">
    <parent link="rl_shank_link"/><child link="rl_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="rl_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="rl_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="rl_foot_joint" type="fixed">
    <parent link="rl_cannon_link"/><child link="rl_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>
  <gazebo reference="rl_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── REAR-RIGHT ── -->
  <link name="rr_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.10"/></geometry></collision>
  </link>
  <joint name="rr_hip_joint" type="revolute">
    <parent link="base_link"/><child link="rr_hip_link"/>
    <origin xyz="-0.48 -0.24 -0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="rr_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="rr_thigh_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.022" izz="0.005" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.10" rpy="0 0 0">
      </origin><geometry><box size="0.070 0.070 0.20"/></geometry></collision>
  </link>
  <joint name="rr_thigh_joint" type="revolute">
    <parent link="rr_hip_link"/><child link="rr_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="rr_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="rr_shank_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.18"/></geometry></collision>
  </link>
  <joint name="rr_knee_joint" type="revolute">
    <parent link="rr_thigh_link"/><child link="rr_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="rr_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="rr_cannon_link">
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.10"/></geometry></collision>
  </link>
  <joint name="rr_cannon_joint" type="revolute">
    <parent link="rr_shank_link"/><child link="rr_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="rr_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="rr_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="rr_foot_joint" type="fixed">
    <parent link="rr_cannon_link"/><child link="rr_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>
  <gazebo reference="rr_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       ROS2 CONTROL — hardware interface
       16 commanded joints: 4x hip(Z) + 4x thigh(Y) + 4x knee(Y) + 4x cannon(Y)
       No passive joints (cart removed — robot is freestanding).
  ═══════════════════════════════════════════════════════ -->

  <!-- ROPE and CART - horse is free-standing root; cart follows via 2.5m rope -->

  <link name="horse_hitch_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry><material name="iron"/></visual>
  </link>
  <joint name="horse_hitch_joint" type="fixed">
    <parent link="base_link"/><child link="horse_hitch_link"/>
    <origin xyz="-0.55 0 -0.12" rpy="0 0 0"/>
  </joint>

  <link name="rope_yaw_link">
    <inertial><mass value="0.3"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="rope_horse_yaw" type="revolute">
    <parent link="horse_hitch_link"/><child link="rope_yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="5.0"/>
    <dynamics damping="6.0" friction="1.5"/>
  </joint>

  <!-- rope_body_link: visual is a 2.5m box extending rearward from horse end -->
  <link name="rope_body_link">
    <inertial><mass value="2.0"/><origin xyz="-1.25 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" iyy="1.042" izz="1.042" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="-1.25 0 0" rpy="0 0 0">
      </origin><geometry><box size="2.50 0.04 0.04"/></geometry><material name="dark_grey"/></visual>
  </link>
  <joint name="rope_horse_pitch" type="revolute">
    <parent link="rope_yaw_link"/><child link="rope_body_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.047" upper="1.047" effort="0" velocity="5.0"/>
    <dynamics damping="3.0" friction="0.5"/>
  </joint>
  <gazebo reference="rope_body_link"><material>Gazebo/DarkGrey</material></gazebo>

  <link name="rope_cart_pitch_link">
    <inertial><mass value="0.3"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="rope_cart_pitch" type="revolute">
    <parent link="rope_body_link"/><child link="rope_cart_pitch_link"/>
    <origin xyz="-2.50 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.047" upper="1.047" effort="0" velocity="5.0"/>
    <dynamics damping="3.0" friction="0.5"/>
  </joint>

  <link name="cart_hitch_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry><material name="iron"/></visual>
  </link>
  <joint name="rope_cart_yaw" type="revolute">
    <parent link="rope_cart_pitch_link"/><child link="cart_hitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="5.0"/>
    <dynamics damping="6.0" friction="1.5"/>
  </joint>

  <link name="cart_base">
    <inertial>
      <mass value="350.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="71.5" iyy="313.0" izz="355.8" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><box size="3.2 1.4 0.7"/></geometry><material name="wood"/></visual>
    <visual><origin xyz="0.2 0 0.35" rpy="0 0 0">
      </origin><geometry><box size="2.6 1.35 0.05"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><box size="3.2 1.4 0.7"/></geometry></collision>
  </link>
  <joint name="cart_base_joint" type="fixed">
    <parent link="cart_hitch_link"/><child link="cart_base"/>
    <origin xyz="-1.60 0 0" rpy="0 0 0"/>
  </joint>
  <gazebo reference="cart_base"><material>Gazebo/WoodPallet</material></gazebo>

  <link name="cart_fl_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_fl_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_fl_wheel_link"/>
    <origin xyz="1.2 0.72 -0.35" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_fl_wheel_link">
    <material>Gazebo/FlatBlack</material><mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd></gazebo>

  <link name="cart_fr_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_fr_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_fr_wheel_link"/>
    <origin xyz="1.2 -0.72 -0.35" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_fr_wheel_link">
    <material>Gazebo/FlatBlack</material><mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd></gazebo>

  <link name="cart_rl_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_rl_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_rl_wheel_link"/>
    <origin xyz="-1.2 0.72 -0.35" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_rl_wheel_link">
    <material>Gazebo/FlatBlack</material><mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd></gazebo>

  <link name="cart_rr_wheel_link">
    <inertial><mass value="8.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.515" iyy="1.000" izz="0.515" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0">
      </origin><geometry><cylinder radius="0.50" length="0.15"/></geometry></collision>
  </link>
  <joint name="cart_rr_wheel_joint" type="continuous">
    <parent link="cart_base"/><child link="cart_rr_wheel_link"/>
    <origin xyz="-1.2 -0.72 -0.35" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <dynamics damping="0.4" friction="0.5"/>
  </joint>
  <gazebo reference="cart_rr_wheel_link">
    <material>Gazebo/FlatBlack</material><mu1>0.85</mu1><mu2>0.85</mu2><kp>1000000</kp><kd>80</kd></gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Front-left -->
    <joint name="fl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-right -->
    <joint name="fr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-left -->
    <joint name="rl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-right -->
    <joint name="rr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">1.8</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.8</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════
       GAZEBO PLUGIN — loads gazebo_ros2_control
  ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robotic_horse_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
