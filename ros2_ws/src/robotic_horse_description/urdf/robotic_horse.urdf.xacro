  </link>
  <joint name="rr_cannon_joint" type="revolute">
    <parent link="rr_shank_link"/><child link="rr_cannon_link"/>
    <origin xyz="0 0 -0.45" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="rr_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="rr_foot_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00072" iyy="0.00072" izz="0.00072" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry></collision>
  </link>
  <joint name="rr_foot_joint" type="fixed">
    <parent link="rr_cannon_link"/><child link="rr_foot_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/>
  </joint>
  <gazebo reference="rr_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>200.0</kd>
    <mu1>2.0</mu1><mu2>2.0</mu2>
    <minDepth>0.005</minDepth>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       CARRIAGE — vis-à-vis style, hitched to bovine robot
       Robot faces -X, carriage trails at +X side.
       Kinematic chain:
         base_link → cow_hitch_pitch (revolute, y, ±0.35 rad)
           → shaft_link (U-fork, 2.35m, bars at ±0.50m to clear body)
             → perch_pitch (revolute, y, at perch)
               → front_assembly_link (perch + front axle + turntable)
                 ├─ cart_fl_wheel_joint (continuous)
                 ├─ cart_fr_wheel_joint (continuous)
                 └─ turntable_yaw_joint (revolute, z, ±45°)
                    → cart_body_link (body, driver, etc.)
                      → rear_axle_joint (fixed)
                        → rear_axle_link
                          ├─ cart_rl_wheel_joint (continuous)
                          └─ cart_rr_wheel_joint (continuous)
       Cow-side hitch: pitch only (Y-axis) — shaft pivots up/down
       Perch-side hitch: pitch (Y-axis) — same as real carriage hitch
       Total: 2 pitch DOF + turntable yaw = 3 DOF
       Shaft bars at ±0.50m (1.0m apart) clear 0.88m body width
       Real measurements from owner's carriage:
         Front wheels ⌀ 85 cm,  Rear wheels ⌀ 105 cm
         Wheelbase 205 cm,  Track 145 cm
         Shaft 235 cm long, U-shaped
         Perch: shaft connects to front axle assembly 50cm fwd of wheel center
         Body: 250 × 110 × 110 cm, ~60 cm off ground
         Driver: ~85 kg on front bench
       Total carriage mass ≈ 105 kg + 85 kg driver = 190 kg
  ═══════════════════════════════════════════════════════ -->

  <!-- Cow-side hitch — pitch only (up/down in forward direction)
       Like a real carriage hitch pivot: shaft can tilt up/down but
       does not yaw or roll relative to the cow body. -->
  <joint name="cow_hitch_pitch_joint" type="revolute">
    <parent link="base_link"/><child link="shaft_link"/>
    <origin xyz="0.0 0 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.35" upper="0.35" effort="0" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- Shaft — U-shaped wooden fork, 2.35m long, extending in +X (behind robot)
       Bars at ±0.50m (1.0m apart) to clear 0.88m body width -->
  <link name="shaft_link">
    <inertial><mass value="15.0"/><origin xyz="1.175 0 0" rpy="0 0 0"/>
      <inertia ixx="0.15" iyy="6.93" izz="7.00" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Left shaft bar -->
    <visual><origin xyz="1.175 0.50 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="1.175 0.50 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry></collision>
    <!-- Right shaft bar -->
    <visual><origin xyz="1.175 -0.50 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="1.175 -0.50 0" rpy="0 0 0"/>
      <geometry><box size="2.35 0.05 0.05"/></geometry></collision>
    <!-- Cross piece at carriage end (tapers to ~0.85m) -->
    <visual><origin xyz="2.30 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.85 0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="2.30 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.85 0.05"/></geometry></collision>
  </link>

  <!-- Perch pitch joint — pivot at front of front axle assembly
       Moderate damping: allows free pitch motion over bumps without oscillation. -->
  <joint name="perch_pitch_joint" type="revolute">
    <parent link="shaft_link"/><child link="front_assembly_link"/>
    <origin xyz="2.35 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.35" upper="0.35" effort="0" velocity="2.0"/>
    <dynamics damping="1.5" friction="0.2"/>
  </joint>

  <!-- Front assembly (perch beam + front axle + turntable pin) ~8 kg -->
  <link name="front_assembly_link">
    <inertial><mass value="8.0"/><origin xyz="0.25 0 -0.15" rpy="0 0 0"/>
      <inertia ixx="0.20" iyy="0.10" izz="0.25" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Perch beam (shaft-to-axle connection) -->
    <visual><origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry><box size="0.50 0.08 0.08"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry><box size="0.50 0.08 0.08"/></geometry></collision>
    <!-- Front axle bar -->
    <visual><origin xyz="0.50 0 -0.37" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0.50 0 -0.37" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry></collision>
    <!-- Turntable circle (fifth-wheel plate) -->
    <visual><origin xyz="0.50 0 -0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.04"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0.50 0 -0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.04"/></geometry></collision>
  </link>

  <!-- ── Front-Left Wheel (⌀85cm) — on front assembly ── -->
  <joint name="cart_fl_wheel_joint" type="continuous">
    <parent link="front_assembly_link"/><child link="cart_fl_wheel_link"/>
    <origin xyz="0.50 0.725 -0.37" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_fl_wheel_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.091" iyy="0.181" izz="0.091" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry></collision>
    <!-- Wheel hub -->
    <visual><origin xyz="0 0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Front-Right Wheel (⌀85cm) — on front assembly ── -->
  <joint name="cart_fr_wheel_joint" type="continuous">
    <parent link="front_assembly_link"/><child link="cart_fr_wheel_link"/>
    <origin xyz="0.50 -0.725 -0.37" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_fr_wheel_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.091" iyy="0.181" izz="0.091" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.425" length="0.05"/></geometry></collision>
    <visual><origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry><material name="iron"/></visual>
  </link>

  <!-- Turntable yaw joint — cart body rotates relative to front axle assembly
       Moderate damping: enough to prevent oscillation but allows smooth turning.
       The cart body's inertia (140 kg) provides natural stability. -->
  <joint name="turntable_yaw_joint" type="revolute">
    <parent link="front_assembly_link"/><child link="cart_body_link"/>
    <origin xyz="0.50 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="0.785" effort="0" velocity="2.0"/>
    <dynamics damping="4.0" friction="0.3"/>
  </joint>

  <!-- Cart body — 250×110×110 cm wooden carriage body
       Origin at turntable center (directly above front wheel center)
       Visuals shifted down so body floor sits at ~60cm off ground
       (turntable origin at z≈0.795m abs → floor at -0.195 rel = 0.60m abs)
       Driver (85 kg) seated on front bench -->
  <link name="cart_body_link">
    <!-- Combined inertia: carriage structure 55 kg + driver 85 kg = 140 kg
         COM shifted down to match lowered body position -->
    <inertial><mass value="140.0"/><origin xyz="0.90 0 0.07" rpy="0 0 0"/>
      <inertia ixx="25.0" iyy="95.0" izz="85.0" ixy="0" ixz="0" iyz="0"/></inertial>

    <!-- Main body floor/deck — abs z ≈ 0.60m -->
    <visual><origin xyz="1.025 0 -0.195" rpy="0 0 0"/>
      <geometry><box size="2.50 1.10 0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="1.025 0 -0.195" rpy="0 0 0"/>
      <geometry><box size="2.50 1.10 0.06"/></geometry></collision>

    <!-- Left side panel -->
    <visual><origin xyz="1.025 0.52 0.195" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="1.025 0.52 0.195" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry></collision>

    <!-- Right side panel -->
    <visual><origin xyz="1.025 -0.52 0.195" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="1.025 -0.52 0.195" rpy="0 0 0"/>
      <geometry><box size="2.20 0.06 0.72"/></geometry></collision>

    <!-- Front panel (cow side, kick board) -->
    <visual><origin xyz="-0.05 0 0.145" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.62"/></geometry><material name="dark_grey"/></visual>

    <!-- Rear panel -->
    <visual><origin xyz="2.10 0 0.145" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.62"/></geometry><material name="dark_grey"/></visual>

    <!-- Center divider panel -->
    <visual><origin xyz="1.025 0 0.145" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.50"/></geometry><material name="dark_grey"/></visual>

    <!-- Front bench seat (driver side, closest to cow) -->
    <visual><origin xyz="0.30 0 0.105" rpy="0 0 0"/>
      <geometry><box size="0.45 0.90 0.08"/></geometry><material name="red_velvet"/></visual>
    <!-- Front seat backrest -->
    <visual><origin xyz="0.08 0 0.325" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.36"/></geometry><material name="wood"/></visual>

    <!-- Rear bench seat -->
    <visual><origin xyz="1.75 0 0.105" rpy="0 0 0"/>
      <geometry><box size="0.45 0.90 0.08"/></geometry><material name="red_velvet"/></visual>
    <!-- Rear seat backrest -->
    <visual><origin xyz="1.97 0 0.325" rpy="0 0 0"/>
      <geometry><box size="0.06 0.90 0.36"/></geometry><material name="wood"/></visual>

    <!-- Driver figure (85 kg, seated on front bench) -->
    <!-- Torso -->
    <visual><origin xyz="0.30 0 0.465" rpy="0 0 0"/>
      <geometry><box size="0.30 0.40 0.55"/></geometry><material name="dark_grey"/></visual>
    <!-- Head -->
    <visual><origin xyz="0.30 0 0.815" rpy="0 0 0"/>
      <geometry><sphere radius="0.12"/></geometry><material name="light_grey"/></visual>

    <!-- Left mudguard / fender (over rear wheels) -->
    <visual><origin xyz="1.85 0.58 -0.245" rpy="0 0 0"/>
      <geometry><box size="0.70 0.12 0.06"/></geometry><material name="wood"/></visual>
    <!-- Right mudguard -->
    <visual><origin xyz="1.85 -0.58 -0.245" rpy="0 0 0"/>
      <geometry><box size="0.70 0.12 0.06"/></geometry><material name="wood"/></visual>

    <!-- Iron underframe / chassis rail (left) -->
    <visual><origin xyz="1.025 0.40 -0.405" rpy="0 0 0"/>
      <geometry><box size="2.60 0.04 0.04"/></geometry><material name="iron"/></visual>
    <!-- Iron underframe / chassis rail (right) -->
    <visual><origin xyz="1.025 -0.40 -0.405" rpy="0 0 0"/>
      <geometry><box size="2.60 0.04 0.04"/></geometry><material name="iron"/></visual>

    <!-- Left carriage lamp bracket -->
    <visual><origin xyz="-0.15 0.50 0.595" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="iron"/></visual>
    <!-- Left lamp housing -->
    <visual><origin xyz="-0.15 0.54 0.745" rpy="0 0 0"/>
      <geometry><box size="0.10 0.10 0.15"/></geometry><material name="iron"/></visual>
    <!-- Right carriage lamp bracket -->
    <visual><origin xyz="-0.15 -0.50 0.595" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="iron"/></visual>
    <!-- Right lamp housing -->
    <visual><origin xyz="-0.15 -0.54 0.745" rpy="0 0 0"/>
      <geometry><box size="0.10 0.10 0.15"/></geometry><material name="iron"/></visual>

    <!-- Folding hood frame (rear, collapsed) -->
    <visual><origin xyz="2.05 0 0.645" rpy="0 0 0"/>
      <geometry><box size="0.08 0.95 0.15"/></geometry><material name="wood"/></visual>
  </link>

  <!-- ── Rear axle (fixed to cart body) ── -->
  <joint name="rear_axle_joint" type="fixed">
    <parent link="cart_body_link"/><child link="rear_axle_link"/>
    <origin xyz="2.05 0 -0.27" rpy="0 0 0"/>
  </joint>
  <link name="rear_axle_link">
    <inertial><mass value="6.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.53" iyy="0.003" izz="0.53" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry><material name="iron"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.40 0.06"/></geometry></collision>
  </link>

  <!-- ── Rear-Left Wheel (⌀105cm) ── -->
  <joint name="cart_rl_wheel_joint" type="continuous">
    <parent link="rear_axle_link"/><child link="cart_rl_wheel_link"/>
    <origin xyz="0 0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_rl_wheel_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.174" iyy="0.345" izz="0.174" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry></collision>
    <visual><origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Rear-Right Wheel (⌀105cm) ── -->
  <joint name="cart_rr_wheel_joint" type="continuous">
    <parent link="rear_axle_link"/><child link="cart_rr_wheel_link"/>
    <origin xyz="0 -0.725 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <link name="cart_rr_wheel_link">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.174" iyy="0.345" izz="0.174" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry><material name="wood"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.525" length="0.06"/></geometry></collision>
    <visual><origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry><material name="iron"/></visual>
  </link>

  <!-- ── Gazebo contact/material for carriage ── -->
  <gazebo reference="shaft_link"><material>Gazebo/Wood</material></gazebo>
  <gazebo reference="front_assembly_link"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="cart_body_link"><material>Gazebo/Wood</material></gazebo>
  <gazebo reference="rear_axle_link"><material>Gazebo/Grey</material></gazebo>

  <gazebo reference="cart_fl_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_fr_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_rl_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>
  <gazebo reference="cart_rr_wheel_link">
    <material>Gazebo/Wood</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <minDepth>0.003</minDepth>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       ROS2 CONTROL — hardware interface
       17 commanded joints: spine(Z) + 4x hip(Z) + 4x thigh(Y) + 4x knee(Y) + 4x cannon(Y)
       Carriage wheels are passive — not included in ros2_control.
  ═══════════════════════════════════════════════════════ -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Spine yaw — articulated spine for turning -->
    <joint name="spine_yaw_joint">
      <command_interface name="position">
        <param name="min">-0.30</param><param name="max">0.30</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-left -->
    <joint name="fl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.30</param><param name="max">1.20</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position">
        <param name="min">-1.80</param><param name="max">-0.10</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-right -->
    <joint name="fr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.30</param><param name="max">1.20</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position">
        <param name="min">-1.80</param><param name="max">-0.10</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.63</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-left -->
    <joint name="rl_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.20</param><param name="max">0.30</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position">
        <param name="min">0.10</param><param name="max">1.80</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-right -->
    <joint name="rr_hip_joint">
      <command_interface name="position">
        <param name="min">-0.35</param><param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_thigh_joint">
      <command_interface name="position">
        <param name="min">-1.20</param><param name="max">0.30</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.55</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position">
        <param name="min">0.10</param><param name="max">1.80</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.10</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_cannon_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">2.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.47</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════
       GAZEBO PLUGIN — loads gazebo_ros2_control
  ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robotic_horse_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
