<?xml version="1.0"?>
<!--
  Robotic Horse — Gazebo / ROS2 URDF
  ===================================
  This is the Gazebo-compatible version of the robot description.
  It extends the base URDF with:
    • <ros2_control> hardware interface tags  (8 controlled joints)
    • <gazebo> plugin tag  (loads gazebo_ros2_control)
    • <gazebo> material + contact tags per link

  Leg layout (top view):
      FL –––– FR
      |        |
      RL –––– RR

  Controlled joints (8 total):
      {fl,fr,rl,rr}_thigh_joint  — hip flexion/extension  (position ctrl)
      {fl,fr,rl,rr}_knee_joint   — knee driven by ballscrew (position ctrl)

  Fixed joints (set at 0, no actuator needed for cart-supported robot):
      {fl,fr,rl,rr}_hip_joint    — lateral hip bracket

  Physical parameters (edit here and in ros2_control.yaml):
    Body mass  : 20 kg
    Thigh      : 0.45 m,  1.5 kg
    Shank      : 0.50 m,  1.0 kg
    Foot sphere: r=0.04 m, 0.2 kg
-->
<robot name="robotic_horse" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════ -->
  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1"/></material>
  <material name="orange">     <color rgba="0.90 0.40 0.00 1"/></material>
  <material name="light_grey"> <color rgba="0.70 0.70 0.70 1"/></material>
  <material name="black">      <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="silver">     <color rgba="0.75 0.75 0.80 1"/></material>
  <material name="body_panel"> <color rgba="0.25 0.25 0.30 1"/></material>
  <material name="wood">       <color rgba="0.55 0.35 0.15 1"/></material>
  <material name="iron">       <color rgba="0.28 0.28 0.28 1"/></material>

  <!-- ═══════════════════════════════════════════════════════
       WAGON ASSEMBLY
       cart_base is the physics root spawned at (-2.50, 0, 0.55).
       Front wheels steer via cart_to_shaft_steer revolute-Z joint.
       Shaft poles slope up from front axle to horse collar.
       shaft_to_horse is revolute-Y so horse can pitch on hills.

       World-frame positions (spawn: x=-2.50, z=0.55):
         Cart centre    : (-2.50,  0,  0.55)
         Front axle     : (-1.80,  0,  0.35)  xyz="0.70 0 -0.20" in cart
         Horse base_link: ( 0.30,  0,  1.00)  xyz="2.10 0 0.65" in shaft_steer
  ═══════════════════════════════════════════════════════ -->

  <!-- ── WAGON BODY (root link) ─────────────────────────────── -->
  <link name="cart_base">
    <inertial>
      <mass value="120.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="11.6" iyy="21.2" izz="29.6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main wagon box -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 1.00 0.40"/></geometry>
      <material name="wood"/>
    </visual>
    <!-- Front footboard -->
    <visual>
      <origin xyz="0.73 0 0.25" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.10"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Rear board -->
    <visual>
      <origin xyz="-0.73 0 0.25" rpy="0 0 0"/>
      <geometry><box size="0.06 1.00 0.10"/></geometry>
      <material name="iron"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 1.00 0.40"/></geometry>
    </collision>
  </link>
  <gazebo reference="cart_base"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ── REAR-LEFT WHEEL ────────────────────────────────── -->
  <link name="cart_wheel_rl">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.157" iyy="0.306" izz="0.157" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
    </collision>
  </link>
  <joint name="cart_to_wheel_rl" type="continuous">
    <parent link="cart_base"/><child link="cart_wheel_rl"/>
    <origin xyz="-0.50  0.55 -0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <gazebo reference="cart_wheel_rl">
    <material>Gazebo/FlatBlack</material>
    <kp>500000.0</kp><kd>50.0</kd><mu1>0.9</mu1><mu2>0.9</mu2>
  </gazebo>

  <!-- ── REAR-RIGHT WHEEL ───────────────────────────────── -->
  <link name="cart_wheel_rr">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.157" iyy="0.306" izz="0.157" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
    </collision>
  </link>
  <joint name="cart_to_wheel_rr" type="continuous">
    <parent link="cart_base"/><child link="cart_wheel_rr"/>
    <origin xyz="-0.50 -0.55 -0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <gazebo reference="cart_wheel_rr">
    <material>Gazebo/FlatBlack</material>
    <kp>500000.0</kp><kd>50.0</kd><mu1>0.9</mu1><mu2>0.9</mu2>
  </gazebo>

  <!-- ── STEERING JOINT (cart yaw -> front wheels + shaft turn together) ── -->
  <!-- Revolute-Z at front axle position in cart_base frame.
       Limits +-35 deg lets cart navigate corners without jackknifing. -->
  <joint name="cart_to_shaft_steer" type="revolute">
    <parent link="cart_base"/><child link="shaft_steer_link"/>
    <origin xyz="0.70 0 -0.20" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.61" upper="0.61" effort="5000" velocity="1.0"/>
    <dynamics damping="10.0" friction="2.0"/>
  </joint>

  <!-- ── SHAFT + FRONT WHEELS ──────────────────────────────── -->
  <!-- Origin = front axle centre.  Poles run from (0,+/-0.25,0)
       up to horse collar at (2.10,+/-0.25,0.65), pitch=17 deg (0.299 rad). -->
   <link name="shaft_steer_link">
    <inertial>
      <mass value="6.0"/>
      <origin xyz="1.70 0 0.525" rpy="0 0 0"/>
      <inertia ixx="0.30" iyy="6.50" izz="6.50" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Left shaft pole (slopes from cart front axle up to horse collar) -->
    <visual>
      <origin xyz="1.70 0.25 0.525" rpy="0 -0.299 0"/>
      <geometry><box size="3.56 0.07 0.07"/></geometry>
      <material name="wood"/>
    </visual>
    <!-- Right shaft pole -->
    <visual>
      <origin xyz="1.70 -0.25 0.525" rpy="0 -0.299 0"/>
      <geometry><box size="3.56 0.07 0.07"/></geometry>
      <material name="wood"/>
    </visual>
    <!-- Front axle crossbar at cart end -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.62 0.10"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Horse collar yoke at shaft tip -->
    <visual>
      <origin xyz="3.40 0 1.05" rpy="0 0 0"/>
      <geometry><box size="0.10 0.62 0.10"/></geometry>
      <material name="iron"/>
    </visual>
    <!-- Front axle cylinder (visual only) -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.04" length="1.20"/></geometry>
      <material name="iron"/>
    </visual>
  </link>
  <gazebo reference="shaft_steer_link"><material>Gazebo/Grey</material></gazebo>

  <!-- ── FRONT-LEFT WHEEL ───────────────────────────────── -->
  <link name="cart_wheel_fl">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.157" iyy="0.306" izz="0.157" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
    </collision>
  </link>
  <joint name="shaft_to_wheel_fl" type="continuous">
    <parent link="shaft_steer_link"/><child link="cart_wheel_fl"/>
    <origin xyz="0  0.55 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <gazebo reference="cart_wheel_fl">
    <material>Gazebo/FlatBlack</material>
    <kp>500000.0</kp><kd>50.0</kd><mu1>0.9</mu1><mu2>0.9</mu2>
  </gazebo>

  <!-- ── FRONT-RIGHT WHEEL ──────────────────────────────── -->
  <link name="cart_wheel_fr">
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.157" iyy="0.306" izz="0.157" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.35" length="0.10"/></geometry>
    </collision>
  </link>
  <joint name="shaft_to_wheel_fr" type="continuous">
    <parent link="shaft_steer_link"/><child link="cart_wheel_fr"/>
    <origin xyz="0 -0.55 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <gazebo reference="cart_wheel_fr">
    <material>Gazebo/FlatBlack</material>
    <kp>500000.0</kp><kd>50.0</kd><mu1>0.9</mu1><mu2>0.9</mu2>
  </gazebo>

  <!-- ── HORSE PITCH JOINT ──────────────────────────────── -->
  <!-- Revolute-Y: horse can pitch +/-15 deg on hills.
       Damping prevents oscillation at the collar. -->
  <joint name="shaft_to_horse" type="revolute">
    <parent link="shaft_steer_link"/>
    <child link="horse_collar_link"/>
    <origin xyz="3.40 0 1.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.15" upper="0.15" effort="3000" velocity="0.5"/>
    <dynamics damping="40.0" friction="10.0"/>
  </joint>

  <!-- Collar link: massless pivot point where shaft meets horse.
       Allows the horse to yaw (turn) freely relative to the shaft,
       simulating a rope-and-collar attachment rather than a rigid bar. -->
  <link name="horse_collar_link">
    <inertial><mass value="0.1"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="horse_yaw_joint" type="revolute">
    <parent link="horse_collar_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="3.0"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════ -->
  <!-- Elk animatronic body: 45kg (frame 18kg + motors 15kg + costume 12kg)
       CoM shifted -0.15m rear to counterbalance neck/head forward mass. -->
  <link name="base_link">
    <inertial>
      <mass value="45.0"/>
      <origin xyz="-0.15 0 0" rpy="0 0 0"/>
      <inertia ixx="1.202" iyy="4.875" izz="5.402" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main body panel -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.10 0.48 0.30"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Top saddle plate -->
    <visual>
      <origin xyz="-0.06 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.70 0.35 0.04"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.10 0.55 0.30"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       NECK + HEAD  (basic elk silhouette geometry)
  ═══════════════════════════════════════════════════════ -->

  <!-- Neck: angled 45 deg forward from vertical.
       Joint origin at front-top of body (withers area). -->
  <link name="neck_link">
    <inertial><mass value="2.5"/><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <inertia ixx="0.080" iyy="0.080" izz="0.015" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.12" length="0.55"/></geometry><material name="body_panel"/></visual>
    <collision><origin xyz="0 0 0.275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.10" length="0.55"/></geometry></collision>
  </link>
  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/><child link="neck_link"/>
    <origin xyz="0.62 0 0.15" rpy="0 -0.698 0"/>
  </joint>
  <gazebo reference="neck_link"><material>Gazebo/Brown</material></gazebo>

  <!-- Head: skull box + snout extension -->
  <link name="head_link">
    <inertial><mass value="1.2"/><origin xyz="0.10 0 0" rpy="0 0 0"/>
      <inertia ixx="0.010" iyy="0.020" izz="0.016" ixy="0" ixz="0" iyz="0"/></inertial>
    <!-- Skull -->
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.40 0.18 0.28"/></geometry><material name="body_panel"/></visual>
    <!-- Snout / muzzle extending forward -->
    <visual><origin xyz="0.32 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.28 0.13 0.17"/></geometry><material name="body_panel"/></visual>
    <!-- Nose tip (darker) -->
    <visual><origin xyz="0.46 0 -0.06" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.10"/></geometry><material name="black"/></visual>
    <!-- Eye sockets -->
    <visual><origin xyz="-0.05 0.09 0.06" rpy="0 0 0"/>
      <geometry><sphere radius="0.028"/></geometry><material name="black"/></visual>
    <visual><origin xyz="-0.05 -0.09 0.06" rpy="0 0 0"/>
      <geometry><sphere radius="0.028"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.55 0.18 0.28"/></geometry></collision>
  </link>
  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/><child link="head_link"/>
    <origin xyz="0 0 0.55" rpy="0 0.698 0"/>
  </joint>
  <gazebo reference="head_link"><material>Gazebo/Brown</material></gazebo>

  <!-- ═══════════════════════════════════════════════════════
       LEG LINKS & JOINTS  (macro-expanded for FL/FR/RL/RR)
  ═══════════════════════════════════════════════════════ -->

  <!-- ── FRONT-LEFT ── -->
  <link name="fl_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.16"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.07" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.14"/></geometry></collision>
  </link>
  <joint name="fl_hip_joint" type="revolute">
    <parent link="base_link"/><child link="fl_hip_link"/>
    <origin xyz="0.55 0.28 -0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_hip_link"><material>Gazebo/Grey</material></gazebo>

  <link name="fl_thigh_link">
    <inertial><mass value="5.5"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <inertia ixx="0.170" iyy="0.170" izz="0.010" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.60"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.04 0 -0.30" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="0.40"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.30" rpy="0 0 0">
      </origin><geometry><box size="0.06 0.06 0.60"/></geometry></collision>
  </link>
  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/><child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.13" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_thigh_link"><material>Gazebo/Orange</material></gazebo>

  <link name="fl_shank_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <inertia ixx="0.122" iyy="0.122" izz="0.004" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.30" rpy="0 0 0">
      </origin><geometry><box size="0.050 0.050 0.60"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.19" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.60"/></geometry></collision>
  </link>
  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/><child link="fl_shank_link"/>
    <origin xyz="0 0 -0.60" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>
  <gazebo reference="fl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Cannon bone (metatarsal/metacarpal): pantograph-kept near vertical -->
  <link name="fl_cannon_link">
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.175" rpy="0 0 0"/>
      <inertia ixx="0.0155" iyy="0.0155" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.175" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.35"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.175" rpy="0 0 0"/>
      <geometry><cylinder radius="0.014" length="0.35"/></geometry></collision>
  </link>
  <joint name="fl_cannon_joint" type="revolute">
    <parent link="fl_shank_link"/><child link="fl_cannon_link"/>
    <origin xyz="0 0 -0.60" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <gazebo reference="fl_cannon_link"><material>Gazebo/DarkGrey</material></gazebo>

    <link name="fl_foot_link">
    <inertial><mass value="0.4"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.06"/></geometry></collision>
  </link>
  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_cannon_link"/><child link="fl_foot_link"/>
    <origin xyz="0 0 -0.35" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fl_foot_link">
    <material>Gazebo/FlatBlack</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── FRONT-RIGHT ── -->
  <link name="fr_hip_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.16"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.07" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.04" length="0.14"/></geometry></collision>
  </link>
  <joint name="fr_hip_joint" type="revolute">
    <parent link="base_link"/><child link="fr_hip_link"/>
    <origin xyz="0.55 -0.28 -0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_hip_link"><material>Gazebo/Grey</material></gazebo>
  <link name="fr_thigh_link">
    <inertial><mass value="5.5"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
      <inertia ixx="0.170" iyy="0.170" izz="0.010" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.30" rpy="0 0 0">
      </origin><geometry><box size="0.06 0.06 0.60"/></geometry><material name="orange"/></visual>
    <!-- Ballscrew actuator tube -->
    <visual><origin xyz="0.04 0 -0.30" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="0.40"/></geometry><material name="silver"/></visual>
    <collision><origin xyz="0 0 -0.30" rpy="0 0 0">
      </origin><geometry><box size="0.06 0.06 0.60"/></geometry></collision>
  </link>
  <joint name="fr_thigh_joint" type="revolute">
    <parent link="fr_hip_link"/><child link="fr_thigh_link"/>
    <origin xyz="0 0 -0.13" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>
  <gazebo reference="fr_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="fr_shank_link">
    <inertial><mass value="4.0"/><origin xyz="0 0 -0.30" rpy="0 0 0"/>
