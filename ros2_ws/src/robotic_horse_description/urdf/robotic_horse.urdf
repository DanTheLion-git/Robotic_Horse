<?xml version="1.0"?>
<!--
  Robotic Horse — Gazebo / ROS2 URDF
  ===================================
  This is the Gazebo-compatible version of the robot description.
  It extends the base URDF with:
    • <ros2_control> hardware interface tags  (8 controlled joints)
    • <gazebo> plugin tag  (loads gazebo_ros2_control)
    • <gazebo> material + contact tags per link

  Leg layout (top view):
      FL ---- FR
      |        |
      RL ---- RR

  Controlled joints (8 total):
      {fl,fr,rl,rr}_thigh_joint  — hip flexion/extension  (position ctrl)
      {fl,fr,rl,rr}_knee_joint   — knee driven by ballscrew (position ctrl)

  Fixed joints (set at 0, no actuator needed for cart-supported robot):
      {fl,fr,rl,rr}_hip_joint    — lateral hip bracket

  Physical parameters (edit here and in ros2_control.yaml):
    Body mass  : 20 kg
    Thigh      : 0.45 m,  1.5 kg
    Shank      : 0.50 m,  1.0 kg
    Foot sphere: r=0.04 m, 0.2 kg
-->
<robot name="robotic_horse">

  <!-- ═══════════════════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════════════════ -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="orange">   <color rgba="0.9 0.4 0.0 1"/></material>
  <material name="light_grey"><color rgba="0.7 0.7 0.7 1"/></material>

  <!-- ═══════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.138" iyy="1.075" izz="1.140" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.80 0.40 0.10"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.80 0.40 0.10"/></geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       LEG LINKS & JOINTS  (macro-expanded for FL/FR/RL/RR)
  ═══════════════════════════════════════════════════════ -->

  <!-- ── FRONT-LEFT ── -->
  <link name="fl_hip_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.08"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.08"/></geometry></collision>
  </link>
  <joint name="fl_hip_joint" type="fixed">
    <parent link="base_link"/><child link="fl_hip_link"/>
    <origin xyz="0.35 0.18 -0.05" rpy="0 0 0"/>
  </joint>

  <link name="fl_thigh_link">
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.225" rpy="0 0 0"/>
      <inertia ixx="0.025" iyy="0.025" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.225" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.45"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry></collision>
  </link>
  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/><child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.08" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="1.2" effort="500" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <gazebo reference="fl_thigh_link"><material>Gazebo/Orange</material></gazebo>

  <link name="fl_shank_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.021" iyy="0.021" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry></collision>
  </link>
  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/><child link="fl_shank_link"/>
    <origin xyz="0 0 -0.45" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="800" velocity="5.0"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <gazebo reference="fl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>

  <link name="fl_foot_link">
    <inertial><mass value="0.2"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_shank_link"/><child link="fl_foot_link"/>
    <origin xyz="0 0 -0.50" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fl_foot_link">
    <material>Gazebo/Grey</material>
    <kp>1000000.0</kp><kd>100.0</kd>
    <mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── FRONT-RIGHT ── -->
  <link name="fr_hip_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.08"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 -0.04" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.03" length="0.08"/></geometry></collision>
  </link>
  <joint name="fr_hip_joint" type="fixed">
    <parent link="base_link"/><child link="fr_hip_link"/>
    <origin xyz="0.35 -0.18 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="fr_thigh_link">
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.225" rpy="0 0 0"/>
      <inertia ixx="0.025" iyy="0.025" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry></collision>
  </link>
  <joint name="fr_thigh_joint" type="revolute">
    <parent link="fr_hip_link"/><child link="fr_thigh_link"/>
    <origin xyz="0 0 -0.08" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="1.2" effort="500" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <gazebo reference="fr_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="fr_shank_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.021" iyy="0.021" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry></collision>
  </link>
  <joint name="fr_knee_joint" type="revolute">
    <parent link="fr_thigh_link"/><child link="fr_shank_link"/>
    <origin xyz="0 0 -0.45" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="800" velocity="5.0"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <gazebo reference="fr_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <link name="fr_foot_link">
    <inertial><mass value="0.2"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="fr_foot_joint" type="fixed">
    <parent link="fr_shank_link"/><child link="fr_foot_link"/>
    <origin xyz="0 0 -0.50" rpy="0 0 0"/>
  </joint>
  <gazebo reference="fr_foot_link">
    <material>Gazebo/Grey</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── REAR-LEFT ── -->
  <link name="rl_hip_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.08"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 -0.04" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.03" length="0.08"/></geometry></collision>
  </link>
  <joint name="rl_hip_joint" type="fixed">
    <parent link="base_link"/><child link="rl_hip_link"/>
    <origin xyz="-0.35 0.18 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="rl_thigh_link">
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.225" rpy="0 0 0"/>
      <inertia ixx="0.025" iyy="0.025" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry></collision>
  </link>
  <joint name="rl_thigh_joint" type="revolute">
    <parent link="rl_hip_link"/><child link="rl_thigh_link"/>
    <origin xyz="0 0 -0.08" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="1.2" effort="500" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <gazebo reference="rl_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="rl_shank_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.021" iyy="0.021" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry></collision>
  </link>
  <joint name="rl_knee_joint" type="revolute">
    <parent link="rl_thigh_link"/><child link="rl_shank_link"/>
    <origin xyz="0 0 -0.45" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="800" velocity="5.0"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <gazebo reference="rl_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <link name="rl_foot_link">
    <inertial><mass value="0.2"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="rl_foot_joint" type="fixed">
    <parent link="rl_shank_link"/><child link="rl_foot_link"/>
    <origin xyz="0 0 -0.50" rpy="0 0 0"/>
  </joint>
  <gazebo reference="rl_foot_link">
    <material>Gazebo/Grey</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ── REAR-RIGHT ── -->
  <link name="rr_hip_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.08"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 -0.04" rpy="0 0 0">
      </origin><geometry><cylinder radius="0.03" length="0.08"/></geometry></collision>
  </link>
  <joint name="rr_hip_joint" type="fixed">
    <parent link="base_link"/><child link="rr_hip_link"/>
    <origin xyz="-0.35 -0.18 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="rr_thigh_link">
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.225" rpy="0 0 0"/>
      <inertia ixx="0.025" iyy="0.025" izz="0.002" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.225" rpy="0 0 0">
      </origin><geometry><box size="0.04 0.04 0.45"/></geometry></collision>
  </link>
  <joint name="rr_thigh_joint" type="revolute">
    <parent link="rr_hip_link"/><child link="rr_thigh_link"/>
    <origin xyz="0 0 -0.08" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="1.2" effort="500" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <gazebo reference="rr_thigh_link"><material>Gazebo/Orange</material></gazebo>
  <link name="rr_shank_link">
    <inertial><mass value="1.0"/><origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.021" iyy="0.021" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 -0.25" rpy="0 0 0">
      </origin><geometry><box size="0.03 0.03 0.50"/></geometry></collision>
  </link>
  <joint name="rr_knee_joint" type="revolute">
    <parent link="rr_thigh_link"/><child link="rr_shank_link"/>
    <origin xyz="0 0 -0.45" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="800" velocity="5.0"/>
    <dynamics damping="0.8" friction="0.1"/>
  </joint>
  <gazebo reference="rr_shank_link"><material>Gazebo/DarkGrey</material></gazebo>
  <link name="rr_foot_link">
    <inertial><mass value="0.2"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry></collision>
  </link>
  <joint name="rr_foot_joint" type="fixed">
    <parent link="rr_shank_link"/><child link="rr_foot_link"/>
    <origin xyz="0 0 -0.50" rpy="0 0 0"/>
  </joint>
  <gazebo reference="rr_foot_link">
    <material>Gazebo/Grey</material>
    <kp>1000000.0</kp><kd>100.0</kd><mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════
       ROS2 CONTROL — hardware interface
       (gazebo_ros2_control reads this at runtime)
  ═══════════════════════════════════════════════════════ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <!-- Front-left -->
    <joint name="fl_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.1</param><param name="max">1.2</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Front-right -->
    <joint name="fr_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.1</param><param name="max">1.2</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-left -->
    <joint name="rl_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.1</param><param name="max">1.2</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Rear-right -->
    <joint name="rr_thigh_joint">
      <command_interface name="position">
        <param name="min">-0.1</param><param name="max">1.2</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position">
        <param name="min">-2.0</param><param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════════
       GAZEBO PLUGIN — loads gazebo_ros2_control
  ═══════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find robotic_horse_control)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
