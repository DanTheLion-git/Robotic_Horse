<?xml version="1.0"?>
<!--
  Highland Cow — PyBullet-compatible URDF
  ========================================
  Stocky, low-CoM quadruped robot.  86 kg total body mass.

  Leg layout (top view):
      FL ———— FR        +X = forward
      |  body  |        +Y = left
      RL ———— RR        +Z = up

  3-segment legs: thigh (0.20 m) + shank (0.18 m) + cannon (0.10 m) + hoof (r 0.04 m)
  16 controlled joints: 4 legs × (hip Z-yaw + thigh Y-pitch + knee Y-pitch + cannon Y-pitch)
  Cannon bone is driven passively by pantograph:
      cannon_angle = 0.08 − (thigh + knee)

  Compatible with PyBullet — NO Gazebo plugins or ros2_control tags.
-->
<robot name="robotic_horse">

  <!-- ════════════════════════════════════════════════════════════
       MATERIALS
  ════════════════════════════════════════════════════════════ -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.4 0.0 1"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.80 1"/>
  </material>
  <material name="body_panel">
    <color rgba="0.25 0.25 0.30 1"/>
  </material>
  <material name="wood">
    <color rgba="0.55 0.35 0.15 1"/>
  </material>
  <material name="iron">
    <color rgba="0.28 0.28 0.28 1"/>
  </material>

  <!-- ════════════════════════════════════════════════════════════
       BASE / BODY   (1.40 × 0.60 × 0.40 m, 86 kg)
  ════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <mass value="86.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.73" iyy="15.19" izz="16.63" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 0.60 0.40"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.40 0.60 0.40"/></geometry>
    </collision>
  </link>

  <!-- ════════════════════════════════════════════════════════════
       HEAD (decorative, fixed to body)
  ════════════════════════════════════════════════════════════ -->

  <!-- Neck -->
  <link name="neck_link">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.020" iyy="0.018" izz="0.015" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.22 0.24 0.26"/></geometry>
      <material name="body_panel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.22 0.24 0.26"/></geometry>
    </collision>
  </link>

  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="neck_link"/>
    <origin xyz="0.68 0 0.12" rpy="0 -0.10 0"/>
  </joint>

  <!-- Head -->
  <link name="head_link">
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.015" izz="0.020" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Skull -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.38 0.34 0.28"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Muzzle -->
    <visual>
      <origin xyz="0.18 0 -0.06" rpy="0 0 0"/>
      <geometry><box size="0.14 0.18 0.14"/></geometry>
      <material name="body_panel"/>
    </visual>
    <!-- Left horn -->
    <visual>
      <origin xyz="-0.04 0.18 0.10" rpy="0 0.45 0.30"/>
      <geometry><cylinder radius="0.025" length="0.50"/></geometry>
      <material name="silver"/>
    </visual>
    <!-- Right horn -->
    <visual>
      <origin xyz="-0.04 -0.18 0.10" rpy="0 0.45 -0.30"/>
      <geometry><cylinder radius="0.025" length="0.50"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.38 0.34 0.28"/></geometry>
    </collision>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/>
    <child link="head_link"/>
    <origin xyz="0.20 0 0.12" rpy="0 0.10 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════
       FRONT-LEFT LEG  (FL)
       Hip at xyz="0.48  0.24  -0.16" from base_link
  ════════════════════════════════════════════════════════════ -->

  <link name="fl_hip_link">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.007" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.12"/></geometry>
    </collision>
  </link>

  <joint name="fl_hip_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fl_hip_link"/>
    <origin xyz="0.48 0.24 -0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.35" upper="0.35" effort="200" velocity="2.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>

  <link name="fl_thigh_link">
    <inertial>
      <mass value="6.0"/>
      <origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <inertia ixx="0.022" iyy="0.022" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <!-- Main thigh tube -->
    <visual>
      <origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <geometry><box size="0.070 0.070 0.20"/></geometry>
      <material name="orange"/>
    </visual>
    <!-- Ballscrew tube -->
    <visual>
      <origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <geometry><box size="0.070 0.070 0.20"/></geometry>
    </collision>
  </link>

  <joint name="fl_thigh_joint" type="revolute">
    <parent link="fl_hip_link"/>
    <child link="fl_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>

  <link name="fl_shank_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><box size="0.050 0.050 0.18"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><box size="0.050 0.050 0.18"/></geometry>
    </collision>
  </link>

  <joint name="fl_knee_joint" type="revolute">
    <parent link="fl_thigh_link"/>
    <child link="fl_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>

  <link name="fl_cannon_link">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry>
    </collision>
  </link>

  <joint name="fl_cannon_joint" type="revolute">
    <parent link="fl_shank_link"/>
    <child link="fl_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="fl_foot_link">
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry>
    </collision>
  </link>

  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_cannon_link"/>
    <child link="fl_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════
       FRONT-RIGHT LEG  (FR)
       Hip at xyz="0.48  -0.24  -0.16" from base_link
  ════════════════════════════════════════════════════════════ -->

  <link name="fr_hip_link">
    <inertial>
      <mass value="4.0"/>
