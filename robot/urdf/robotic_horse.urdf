    <visual>
      <origin xyz="0.040 0 -0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.13"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10" rpy="0 0 0"/>
      <geometry><box size="0.070 0.070 0.20"/></geometry>
    </collision>
  </link>

  <joint name="rr_thigh_joint" type="revolute">
    <parent link="rr_hip_link"/>
    <child link="rr_thigh_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="500" velocity="3.0"/>
    <dynamics damping="2.5" friction="0.3"/>
  </joint>

  <link name="rr_shank_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <inertia ixx="0.015" iyy="0.015" izz="0.003" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><box size="0.050 0.050 0.18"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><box size="0.050 0.050 0.18"/></geometry>
    </collision>
  </link>

  <joint name="rr_knee_joint" type="revolute">
    <parent link="rr_thigh_link"/>
    <child link="rr_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="800" velocity="5.0"/>
    <dynamics damping="3.5" friction="0.3"/>
  </joint>

  <link name="rr_cannon_link">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.0011" iyy="0.0011" izz="0.0002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry>
    </collision>
  </link>

  <joint name="rr_cannon_joint" type="revolute">
    <parent link="rr_shank_link"/>
    <child link="rr_cannon_link"/>
    <origin xyz="0 0 -0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="6.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="rr_foot_link">
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.00026" izz="0.00026" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.04"/></geometry>
    </collision>
  </link>

  <joint name="rr_foot_joint" type="fixed">
    <parent link="rr_cannon_link"/>
    <child link="rr_foot_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0 0"/>
  </joint>
  <!-- ════════════════════════════════════════════════════════════
       CARRIAGE — hitched behind the horse
       Total carriage mass ≈ 64 kg (+ 30 kg payload)
       Front wheels ⌀ 85 cm, Rear wheels ⌀ 105 cm
       Track 140 cm, Wheelbase 205 cm
  ════════════════════════════════════════════════════════════ -->

  <!-- Hitch yaw (base_link → hitch_link) -->
  <joint name="horse_hitch_joint" type="revolute">
    <parent link="base_link"/>
    <child link="hitch_link"/>
    <origin xyz="-0.70 0 -0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="0" velocity="2.0"/>
    <dynamics damping="5.0" friction="0.1"/>
  </joint>
  <link name="hitch_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.0005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.10"/></geometry>
      <material name="iron"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.10"/></geometry>
    </collision>
  </link>

  <!-- Hitch pitch (hitch_link → tongue_link) -->
  <joint name="hitch_pitch_joint" type="revolute">
    <parent link="hitch_link"/>
    <child link="tongue_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3" upper="0.3" effort="0" velocity="2.0"/>
    <dynamics damping="10.0" friction="0.1"/>
  </joint>
  <link name="tongue_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="-0.40 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" iyy="0.027" izz="0.027" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.40 0 0" rpy="0 0 0"/>
      <geometry><box size="0.80 0.06 0.04"/></geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <origin xyz="-0.40 0 0" rpy="0 0 0"/>
      <geometry><box size="0.80 0.06 0.04"/></geometry>
    </collision>
  </link>

  <!-- Cart base (tongue_link → cart_base_link) -->
  <joint name="cart_base_joint" type="fixed">
    <parent link="tongue_link"/>
    <child link="cart_base_link"/>
    <origin xyz="-0.80 0 0.10" rpy="0 0 0"/>
  </joint>
  <link name="cart_base_link">
    <inertial>
      <mass value="34.0"/>
      <origin xyz="-0.60 0 0" rpy="0 0 0"/>
      <inertia ixx="1.82" iyy="4.08" izz="5.90" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.60 0 0" rpy="0 0 0"/>
      <geometry><box size="1.20 0.80 0.05"/></geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <origin xyz="-0.60 0 0" rpy="0 0 0"/>
      <geometry><box size="1.20 0.80 0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.80 0 0.175" rpy="0 0 0"/>
      <geometry><box size="0.40 0.70 0.30"/></geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <origin xyz="-0.80 0 0.175" rpy="0 0 0"/>
      <geometry><box size="0.40 0.70 0.30"/></geometry>
    </collision>
  </link>

  <!-- Front axle (steering) -->
  <joint name="front_axle_joint" type="revolute">
    <parent link="cart_base_link"/>
    <child link="front_axle_link"/>
    <origin xyz="-0.10 0 -0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.4" upper="0.4" effort="0" velocity="2.0"/>
    <dynamics damping="20.0" friction="0.1"/>
  </joint>
  <link name="front_axle_link">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.423" iyy="0.001" izz="0.423" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.30 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.30 0.06"/></geometry>
    </collision>
  </link>

  <!-- Rear axle (fixed) -->
  <joint name="rear_axle_joint" type="fixed">
