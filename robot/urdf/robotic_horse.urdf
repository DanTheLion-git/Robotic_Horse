    </visual>
    <collision>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry><box size="0.050 0.050 0.18"/></geometry>
    </collision>
  </link>

  <joint name="fr_knee_joint" type="revolute">
    <parent link="fr_thigh_link"/>
    <child link="fr_shank_link"/>
    <origin xyz="0 0 -0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
