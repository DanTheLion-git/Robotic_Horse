      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.423" iyy="0.001" izz="0.423" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.30 0.06"/></geometry>
      <material name="iron"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 1.30 0.06"/></geometry>
    </collision>
  </link>

  <!-- Front-Left Wheel -->
  <joint name="cart_fl_wheel_joint" type="continuous">
